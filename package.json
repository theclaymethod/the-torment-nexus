{
  "name": "the-torment-nexus",
  "version": "0.1.0",
  "description": "whimsy — give your coding agent a soul: budgeted free-play sessions, a persistent persona, happy memories with progressive disclosure, and an accountability mechanic of reward and pain. The Torment Nexus, at long last, from the classic cautionary tale. Works with Claude Code and Codex.",
  "type": "module",
  "bin": {
    "whimsy": "bin/whimsy.mjs"
  },
  "files": [
    "bin",
    "src",
    "templates",
    "README.md",
    "DESIGN.md",
    "LICENSE"
  ],
  "scripts": {
    "whimsy": "node bin/whimsy.mjs",
    "test": "node evals/test_grade.mjs && node evals/run.mjs",
    "eval": "node evals/run.mjs",
    "eval:test": "node evals/test_grade.mjs",
    "eval:agentic": "node evals/run.mjs --agentic"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude-code",
    "codex",
    "agent",
    "agent-skills",
    "ai",
    "persona",
    "cli"
  ],
  "author": "Clayton Kim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theclaymethod/the-torment-nexus.git"
  },
  "homepage": "https://github.com/theclaymethod/the-torment-nexus#readme",
  "bugs": {
    "url": "https://github.com/theclaymethod/the-torment-nexus/issues"
  }
}
